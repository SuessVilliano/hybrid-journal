{
  "name": "PostLike",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string",
      "description": "Liked post ID"
    },
    "trader_profile_id": {
      "type": "string",
      "description": "Liker's profile ID"
    }
  },
  "required": [
    "post_id",
    "trader_profile_id"
  ],
  "rls": {
    "create": {},
    "read": {},
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}